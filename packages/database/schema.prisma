generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime: pooler de transação (pgbouncer/6543). Migrations precisam de conexão de sessão.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  CREDITOR
  DEBTOR
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum DebtStatus {
  GREEN
  YELLOW
  ORANGE
  RED
}

enum RatePeriod {
  MONTHLY
  ANNUAL
}

enum ConsentState {
  NEVER
  GRANTED
  REVOKED
}

enum NotificationType {
  DUE_SOON // legado (mantido p/ registros antigos); a geração agora usa as réguas abaixo
  DUE_15
  DUE_7
  DUE_3
  DUE_TODAY
  OVERDUE
}

model Tenant {
  id        String       @id @default(uuid())
  name      String
  orgCode   String       @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  users     User[]
  debtors   Debtor[]
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique
  email      String   @unique
  role       UserRole
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  debtor     Debtor?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model Debtor {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  userId     String?   @unique
  user       User?     @relation(fields: [userId], references: [id])
  name       String
  email      String?
  // Localização legada (string inerte) — mantida por compatibilidade; o histórico real
  // vai para LocationPing. O compartilhamento é por CONSENTIMENTO explícito e revogável
  // (modelo voluntário tipo Life360): só grava posição quando locationConsent = GRANTED.
  lastLocation String?
  locationConsent   ConsentState @default(NEVER)
  locationConsentAt DateTime?
  locationRevokedAt DateTime?
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
  debts      Debt[]
  locationPings LocationPing[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, email])
}

// Posição compartilhada VOLUNTARIAMENTE pelo próprio devedor (consentimento GRANTED).
// FK composta (debtorId, tenantId) garante paridade de tenant. Sob RLS (forced).
model LocationPing {
  id         String   @id @default(uuid())
  tenantId   String
  debtorId   String
  debtor     Debtor   @relation(fields: [debtorId, tenantId], references: [id, tenantId])
  lat        Float
  lng        Float
  accuracy   Float?
  battery    Int?
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([debtorId, recordedAt])
}

model Debt {
  id          String     @id @default(uuid())
  tenantId    String
  debtorId    String
  // FK composta (debtorId, tenantId) → Debtor(id, tenantId): o banco garante que a
  // dívida e o devedor pertencem ao MESMO tenant (paridade de tenant). A integridade
  // com Tenant é transitiva via Debtor.
  debtor      Debtor     @relation(fields: [debtorId, tenantId], references: [id, tenantId])
  description String?
  // Etiquetas livres da operação (ex.: "negociando", "judicial"). Normalizadas no app
  // (minúsculas, sem duplicatas, limite de quantidade/tamanho). Coluna aditiva.
  tags        String[]   @default([])
  principal   Decimal    @db.Decimal(14, 2)
  rate        Decimal    @db.Decimal(9, 6)
  ratePeriod  RatePeriod @default(MONTHLY)
  currency    String     @default("BRL")
  startDate   DateTime
  dueDate     DateTime
  status      DebtStatus @default(GREEN)
  // Pagamentos: total abatido e quando foi quitada (paga em total). Devido agora =
  // saldo bruto − paidAmount (piso 0); settledAt != null ⇒ quitada (devido 0).
  paidAmount  Decimal    @default(0) @db.Decimal(14, 2)
  settledAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
  @@index([debtorId])
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  debtorId  String?
  debtId    String?
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@unique([debtId, type])
  @@index([tenantId])
}

model DebtorAccess {
  id         String    @id @default(uuid())
  debtorId   String    @unique
  tenantId   String
  tokenHash  String    @unique
  active     Boolean   @default(true)
  lastSeenAt DateTime?
  rotatedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model DebtorLoginEvent {
  id       String   @id @default(uuid())
  debtorId String
  tenantId String
  success  Boolean
  ip       String?
  at       DateTime @default(now())

  @@index([tenantId])
  @@index([debtorId, at])
}
