generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime: pooler de transação (pgbouncer/6543). Migrations precisam de conexão de sessão.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER // admin supremo / proprietário — superconjunto do SUPER_ADMIN (pode revogar admins)
  SUPER_ADMIN
  CREDITOR
  DEBTOR
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum TenantApproval {
  PENDING
  APPROVED
  REJECTED
}

enum DebtStatus {
  GREEN
  YELLOW
  ORANGE
  RED
}

enum RatePeriod {
  MONTHLY
  ANNUAL
}

enum PlatformEventType {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  LINK_USED
  LINK_CREATED
  LINK_ROTATED
  ACCESS_REVOKED
  ACCESS_REACTIVATED
  OPERATION_CREATED
  OPERATION_UPDATED
  OPERATION_PAID
  PAYMENT_CLAIMED // sobrinho informou um pagamento (aguarda confirmação do padrinho)
  LOCATION_CONSENT // sobrinho concedeu/recusou/revogou o compartilhamento de localização
  CLIENT_CREATED
  TENANT_APPROVED
  TENANT_SUSPENDED
  ERROR
  IMPORTANT
}

enum LocationConsentState {
  NEVER // ainda não decidiu
  DECLINED // recusou no opt-in (→ notifica o padrinho)
  GRANTED // compartilhando (envia pings)
  REVOKED // parou (desligou nas configurações / removeu permissão do SO)
}

enum PaymentClaimStatus {
  PENDING // sobrinho informou, padrinho ainda não decidiu
  CONFIRMED // padrinho confirmou → vira pagamento de fato
  REJECTED // padrinho recusou (não bate)
}

enum NotificationType {
  DUE_SOON // legado (mantido p/ registros antigos); a geração agora usa as réguas abaixo
  DUE_15
  DUE_7
  DUE_3
  DUE_1
  DUE_TODAY
  OVERDUE
}

model Tenant {
  id        String         @id @default(uuid())
  name      String
  orgCode   String         @unique
  status    TenantStatus   @default(ACTIVE)
  // Gate de aprovação pelo super-admin. Tenants antigos = APPROVED (default, não quebram);
  // novos credores entram PENDING e só operam após aprovação.
  approval  TenantApproval @default(APPROVED)
  createdAt DateTime       @default(now())
  users     User[]
  debtors   Debtor[]
}

// Log unificado de eventos da plataforma (login/logout, uso de links, operações, clientes,
// revogações, eventos importantes). Append-only, GLOBAL (sem RLS) — o super-admin lê cross-tenant
// e filtra por tenantId/tipo/data. tenantId nulo = evento de plataforma (super-admin/sistema).
model PlatformEvent {
  id         String            @id @default(uuid())
  tenantId   String?
  actorType  String // CREDITOR | DEBTOR | SUPER_ADMIN | SYSTEM
  actorId    String?
  type       PlatformEventType
  targetType String?
  targetId   String?
  detail     Json?
  ip         String?
  at         DateTime          @default(now())

  @@index([at])
  @@index([tenantId, at])
  @@index([type, at])
}

// Auditoria das ações do super-admin (aprovar/suspender/etc.). Append-only. Sem RLS (global).
model AdminAuditLog {
  id              String   @id @default(uuid())
  actorSupabaseId String
  actorEmail      String?
  action          String
  targetType      String
  targetId        String
  detail          Json?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique
  email      String   @unique
  role       UserRole
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  debtor     Debtor?
  // Force-logout instantâneo: tokens emitidos ANTES deste instante são rejeitados (denylist).
  revokedAfter DateTime?
  // Aceite único do PADRINHO (credor) ao primeiro acesso: termos de responsabilidade + aviso
  // legal de isenção, numa tela só. Null = ainda não aceitou (gate manda para /termos).
  // Só se aplica a CREDITOR; OWNER/SUPER_ADMIN/DEBTOR não veem a tela.
  termsAcceptedAt DateTime?
  termsVersion    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model Debtor {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  userId     String?   @unique
  user       User?     @relation(fields: [userId], references: [id])
  name       String
  email      String?
  // Ponto de extensão INERTE p/ um futuro módulo de localização (opcional, voluntário,
  // SIMULADO). Nenhum código grava/lê isto: sem rastreamento real de pessoas. Ver
  // @pacific/shared/location (contratos) e o painel "Em desenvolvimento" no web.
  lastLocation String?
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
  debts      Debt[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, email])
}

model Debt {
  id          String     @id @default(uuid())
  tenantId    String
  debtorId    String
  // FK composta (debtorId, tenantId) → Debtor(id, tenantId): o banco garante que a
  // dívida e o devedor pertencem ao MESMO tenant (paridade de tenant). A integridade
  // com Tenant é transitiva via Debtor.
  debtor      Debtor     @relation(fields: [debtorId, tenantId], references: [id, tenantId])
  description String?
  // Etiquetas livres da operação (ex.: "negociando", "judicial"). Normalizadas no app
  // (minúsculas, sem duplicatas, limite de quantidade/tamanho). Coluna aditiva.
  tags        String[]   @default([])
  principal   Decimal    @db.Decimal(14, 2)
  rate        Decimal    @db.Decimal(9, 6)
  ratePeriod  RatePeriod @default(MONTHLY)
  currency    String     @default("BRL")
  startDate   DateTime
  dueDate     DateTime
  status      DebtStatus @default(GREEN)
  // Pagamentos: total abatido e quando foi quitada (paga em total). Devido agora =
  // saldo bruto − paidAmount (piso 0); settledAt != null ⇒ quitada (devido 0).
  paidAmount  Decimal    @default(0) @db.Decimal(14, 2)
  settledAt   DateTime?
  // Soft-delete (lixeira): excluir marca deletedAt; restaurável por 30 dias; um job depura.
  // TODAS as leituras de carteira/dashboard filtram deletedAt = null.
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
  @@index([debtorId])
  // Carteira ordena por vencimento dentro do tenant (dashboard/portfolio) — escala com o volume.
  @@index([tenantId, dueDate])
  // Lixeira: lista por tenant filtrando deletedAt; o job de depuração varre por data.
  @@index([tenantId, deletedAt])
}

// Pagamento INFORMADO pelo sobrinho, aguardando confirmação do padrinho (loop de mão dupla).
// Confirmar → vira pagamento de fato (DebtsService.pay). Não move dinheiro; é registro/acordo.
// Global (filtrado por tenantId em código + RLS).
model PaymentClaim {
  id         String             @id @default(uuid())
  tenantId   String
  debtId     String
  debtorId   String
  amount     Decimal            @db.Decimal(14, 2)
  note       String?
  status     PaymentClaimStatus @default(PENDING)
  claimedAt  DateTime           @default(now())
  resolvedAt DateTime?
  createdAt  DateTime           @default(now())

  @@index([tenantId, status])
  @@index([debtId])
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  debtorId  String?
  debtId    String?
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@unique([debtId, type])
  @@index([tenantId])
  // Listagem de notificações ordena por data dentro do tenant.
  @@index([tenantId, createdAt])
}

// Token de push do dispositivo do sobrinho (app nativo). O envio em si (FCM) é externo/manual;
// aqui só registramos o token p/ quando a entrega for ligada. Global (filtrado por debtor).
model DeviceToken {
  id         String   @id @default(uuid())
  tenantId   String
  debtorId   String
  token      String   @unique
  platform   String // ios | android | web
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([tenantId, debtorId])
}

model DebtorAccess {
  id         String    @id @default(uuid())
  debtorId   String    @unique
  tenantId   String
  tokenHash  String    @unique
  active     Boolean   @default(true)
  lastSeenAt DateTime?
  rotatedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model DebtorLoginEvent {
  id       String   @id @default(uuid())
  debtorId String
  tenantId String
  success  Boolean
  ip       String?
  at       DateTime @default(now())

  @@index([tenantId])
  @@index([debtorId, at])
}

// ── Módulo de Localização (compartilhamento CONSENTIDO; ver docs/LOCATION_DESIGN.md) ──────────
// Tudo tenant-scoped + RLS FORCE. Posição real só de devedores com consentimento GRANTED.

// Consentimento por devedor (1 linha). Máquina de estados NEVER→GRANTED→REVOKED, DECLINED na recusa.
model LocationConsent {
  debtorId    String               @id
  tenantId    String
  state       LocationConsentState @default(NEVER)
  consentText String? // versão do texto aceito (para auditoria/LGPD)
  grantedAt   DateTime?
  revokedAt   DateTime?
  declinedAt  DateTime?
  updatedAt   DateTime             @updatedAt

  @@index([tenantId, state])
}

// Última posição conhecida (1 por devedor) — leitura barata do mapa do padrinho.
model DebtorPosition {
  debtorId   String   @id
  tenantId   String
  lat        Decimal  @db.Decimal(9, 6)
  lng        Decimal  @db.Decimal(9, 6)
  accuracy   Int? // metros
  battery    Int? // 0-100
  recordedAt DateTime

  @@index([tenantId])
}

// Histórico de posições (trajeto). Alto volume → retenção curta (RetentionScheduler).
model LocationPing {
  id         String   @id @default(uuid())
  tenantId   String
  debtorId   String
  lat        Decimal  @db.Decimal(9, 6)
  lng        Decimal  @db.Decimal(9, 6)
  accuracy   Int?
  battery    Int?
  recordedAt DateTime

  @@index([tenantId, debtorId, recordedAt])
}

// Cercas / locais frequentes (por tenant).
model Geofence {
  id        String   @id @default(uuid())
  tenantId  String
  label     String
  lat       Decimal  @db.Decimal(9, 6)
  lng       Decimal  @db.Decimal(9, 6)
  radiusM   Int
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// Entrada/saída de cerca (derivado dos pings).
model GeofenceEvent {
  id         String   @id @default(uuid())
  tenantId   String
  debtorId   String
  geofenceId String
  type       String // ARRIVAL | DEPARTURE
  occurredAt DateTime @default(now())

  @@index([tenantId, debtorId, occurredAt])
}

// REL-1 — Relatório mensal automático (in-app; sem envio externo). Um por (tenant, mês).
// Gerado por um job mensal (ou sob demanda); arquiva os números do mês para retenção/histórico.
model MonthlyReport {
  id              String   @id @default(uuid())
  tenantId        String
  month           String // 'YYYY-MM'
  totalLent       Decimal  @db.Decimal(14, 2)
  totalReceivable Decimal  @db.Decimal(14, 2)
  totalReceived   Decimal  @db.Decimal(14, 2)
  totalOverdue    Decimal  @db.Decimal(14, 2)
  opsActive       Int
  opsSettled      Int
  healthScore     Int
  healthState     String
  generatedAt     DateTime @default(now())

  @@unique([tenantId, month])
  @@index([tenantId, month])
}

// Estatísticas materializadas por tenant — agregados caros (computados a partir de Debt sob RLS)
// pré-calculados por um job diário. O overview do super-admin LÊ daqui (1 linha por tenant) em vez
// de varrer todas as dívidas de todos os credores a cada acesso → escala p/ milhares de credores.
// Tolerância de até ~24h de defasagem no overview (aceitável; o dashboard do credor é sempre vivo).
model TenantStats {
  tenantId        String   @id
  opsTotal        Int      @default(0)
  opsActive       Int      @default(0)
  opsOverdue      Int      @default(0)
  totalLent       Decimal  @default(0) @db.Decimal(14, 2)
  totalReceivable Decimal  @default(0) @db.Decimal(14, 2)
  totalReceived   Decimal  @default(0) @db.Decimal(14, 2)
  loginsToday     Int      @default(0)
  refreshedAt     DateTime @default(now())
}

// Snapshot SEMANAL da saúde da carteira (in-app; sem envio externo). Um por (tenant, semana),
// gravado de forma oportunista quando o credor abre a inteligência. Alimenta a tendência de
// risco (📈➖📉), o histórico visual e o "resumo da semana". Global (filtrado por tenantId).
model PortfolioSnapshot {
  id             String   @id @default(uuid())
  tenantId       String
  weekStart      DateTime // segunda-feira (UTC) da semana ISO
  healthScore    Int
  state          String // HEALTHY | ATTENTION | CRITICAL
  receivable     Decimal  @db.Decimal(14, 2)
  overdue        Decimal  @db.Decimal(14, 2)
  expectedProfit Decimal  @db.Decimal(14, 2)
  opsActive      Int
  capturedAt     DateTime @default(now())

  @@unique([tenantId, weekStart])
  @@index([tenantId, weekStart])
}
