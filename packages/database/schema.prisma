generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime: pooler de transação (pgbouncer/6543). Migrations precisam de conexão de sessão.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  CREDITOR
  DEBTOR
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum TenantApproval {
  PENDING
  APPROVED
  REJECTED
}

enum DebtStatus {
  GREEN
  YELLOW
  ORANGE
  RED
}

enum RatePeriod {
  MONTHLY
  ANNUAL
}

enum PlatformEventType {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  LINK_USED
  LINK_CREATED
  LINK_ROTATED
  ACCESS_REVOKED
  ACCESS_REACTIVATED
  OPERATION_CREATED
  OPERATION_UPDATED
  OPERATION_PAID
  CLIENT_CREATED
  TENANT_APPROVED
  TENANT_SUSPENDED
  ERROR
  IMPORTANT
}

enum NotificationType {
  DUE_SOON // legado (mantido p/ registros antigos); a geração agora usa as réguas abaixo
  DUE_15
  DUE_7
  DUE_3
  DUE_TODAY
  OVERDUE
}

model Tenant {
  id        String         @id @default(uuid())
  name      String
  orgCode   String         @unique
  status    TenantStatus   @default(ACTIVE)
  // Gate de aprovação pelo super-admin. Tenants antigos = APPROVED (default, não quebram);
  // novos credores entram PENDING e só operam após aprovação.
  approval  TenantApproval @default(APPROVED)
  createdAt DateTime       @default(now())
  users     User[]
  debtors   Debtor[]
}

// Log unificado de eventos da plataforma (login/logout, uso de links, operações, clientes,
// revogações, eventos importantes). Append-only, GLOBAL (sem RLS) — o super-admin lê cross-tenant
// e filtra por tenantId/tipo/data. tenantId nulo = evento de plataforma (super-admin/sistema).
model PlatformEvent {
  id         String            @id @default(uuid())
  tenantId   String?
  actorType  String // CREDITOR | DEBTOR | SUPER_ADMIN | SYSTEM
  actorId    String?
  type       PlatformEventType
  targetType String?
  targetId   String?
  detail     Json?
  ip         String?
  at         DateTime          @default(now())

  @@index([at])
  @@index([tenantId, at])
  @@index([type, at])
}

// Auditoria das ações do super-admin (aprovar/suspender/etc.). Append-only. Sem RLS (global).
model AdminAuditLog {
  id              String   @id @default(uuid())
  actorSupabaseId String
  actorEmail      String?
  action          String
  targetType      String
  targetId        String
  detail          Json?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique
  email      String   @unique
  role       UserRole
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  debtor     Debtor?
  // Force-logout instantâneo: tokens emitidos ANTES deste instante são rejeitados (denylist).
  revokedAfter DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model Debtor {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  userId     String?   @unique
  user       User?     @relation(fields: [userId], references: [id])
  name       String
  email      String?
  // Ponto de extensão INERTE p/ um futuro módulo de localização (opcional, voluntário,
  // SIMULADO). Nenhum código grava/lê isto: sem rastreamento real de pessoas. Ver
  // @pacific/shared/location (contratos) e o painel "Em desenvolvimento" no web.
  lastLocation String?
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
  debts      Debt[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, email])
}

model Debt {
  id          String     @id @default(uuid())
  tenantId    String
  debtorId    String
  // FK composta (debtorId, tenantId) → Debtor(id, tenantId): o banco garante que a
  // dívida e o devedor pertencem ao MESMO tenant (paridade de tenant). A integridade
  // com Tenant é transitiva via Debtor.
  debtor      Debtor     @relation(fields: [debtorId, tenantId], references: [id, tenantId])
  description String?
  // Etiquetas livres da operação (ex.: "negociando", "judicial"). Normalizadas no app
  // (minúsculas, sem duplicatas, limite de quantidade/tamanho). Coluna aditiva.
  tags        String[]   @default([])
  principal   Decimal    @db.Decimal(14, 2)
  rate        Decimal    @db.Decimal(9, 6)
  ratePeriod  RatePeriod @default(MONTHLY)
  currency    String     @default("BRL")
  startDate   DateTime
  dueDate     DateTime
  status      DebtStatus @default(GREEN)
  // Pagamentos: total abatido e quando foi quitada (paga em total). Devido agora =
  // saldo bruto − paidAmount (piso 0); settledAt != null ⇒ quitada (devido 0).
  paidAmount  Decimal    @default(0) @db.Decimal(14, 2)
  settledAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
  @@index([debtorId])
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  debtorId  String?
  debtId    String?
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@unique([debtId, type])
  @@index([tenantId])
}

model DebtorAccess {
  id         String    @id @default(uuid())
  debtorId   String    @unique
  tenantId   String
  tokenHash  String    @unique
  active     Boolean   @default(true)
  lastSeenAt DateTime?
  rotatedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
}

model DebtorLoginEvent {
  id       String   @id @default(uuid())
  debtorId String
  tenantId String
  success  Boolean
  ip       String?
  at       DateTime @default(now())

  @@index([tenantId])
  @@index([debtorId, at])
}
